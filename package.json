{
  "name": "aiuta-web-sdk",
  "version": "5.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "// 🔍 ": "Code Quality",
    "fmt": "prettier . --check",
    "fmt:fix": "prettier . --write",
    "lint": "eslint --report-unused-disable-directives && tsc --noEmit",
    "lint:fix": "eslint --fix",
    "// 📱 ": "Build App",
    "build:app:debug": "vite build --config vite.config.app.ts --mode debug",
    "build:app:dev": "vite build --config vite.config.app.ts --mode dev",
    "build:app:preprod": "vite build --config vite.config.app.ts --mode preprod",
    "build:app": "vite build --config vite.config.app.ts",
    "// 📦 ": "Build SDK",
    "build:sdk:debug": "vite build --config vite.config.sdk.ts --mode debug",
    "build:sdk:dev": "vite build --config vite.config.sdk.ts --mode dev",
    "build:sdk:preprod": "vite build --config vite.config.sdk.ts --mode preprod",
    "build:sdk": "vite build --config vite.config.sdk.ts",
    "// 🧪 ": "Build Demo",
    "build:demo:debug": "vite build --config vite.config.demo.ts --mode debug",
    "build:demo:dev": "vite build --config vite.config.demo.ts --mode dev",
    "build:demo:preprod": "vite build --config vite.config.demo.ts --mode preprod",
    "build:demo": "vite build --config vite.config.demo.ts",
    "// 🏗️ ": "Build All",
    "build:debug": "npm run build:app:debug && npm run build:sdk:debug && npm run build:demo:debug",
    "build:dev": "npm run build:app:dev && npm run build:sdk:dev && npm run build:demo:dev",
    "build:preprod": "npm run build:app:preprod && npm run build:sdk:preprod && npm run build:demo:preprod",
    "build": "npm run build:app && npm run build:sdk && npm run build:demo",
    "// 🚀 ": "Development",
    "local": "concurrently -k -n app,demo -c blue,magenta \"vite --config vite.config.app.ts --mode debug\" \"vite --config vite.config.demo.ts --mode debug\"",
    "local:docs": "cp -rf ./dist/sdk/index.umd.js ../docs/docs/js/ && rm -rf ../docs/docs/app && cp -rf ./dist/app ../docs/docs",
    "local:run": "open 'https://nmac.local/docs/sdk/web/demo/'",
    "local:debug": "vite --debug react-refresh --config vite.config.app.ts --mode debug",
    "local:unsafe": "npm run build:debug && npm run local:docs && npm run local:run && npm run local:debug"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "@tanstack/react-query": "^5.90.10",
    "@types/uuid": "^10.0.0",
    "bowser": "^2.12.1",
    "dayjs": "^1.11.18",
    "formidable": "^3.5.4",
    "qr-code-styling": "^1.9.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.8.0",
    "tslib": "^2.8.1",
    "uuid": "^12.0.0"
  },
  "devDependencies": {
    "@types/formidable": "^3.4.5",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^24.2.0",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.11",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.90.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
